---
import Heading from "@/components/Heading/index.astro";
import Text from "@/components/Text/index.astro";
import { getTechnologyLabel, toPlainText } from "@/utils/pageBuilder/helpers";
import type { Props } from "./index.type";

const { entry, index } = Astro.props as Props;
---

<div
    class:list={[
        "experience-timeline-card grid gap-4 rounded-2xl border border-paper/20 p-4 hover:shadow-xl hover:shadow-paper/20 transition-all duration-300 lg:w-[calc(50%-1.5rem)] lg:items-center",
        index % 2 === 0 ? "lg:mr-auto" : "lg:ml-auto",
    ]}
>
    <div>
        <Text
            size="2xs"
            className="mb-2 inline-flex rounded py-0.5 font-semibold uppercase text-accent-orange"
        >
            {entry.period}
        </Text>
        <Heading as="h3" size="3xl">
            {entry.company}
        </Heading>
        {
            entry.role && (
                <Text size="base" className="mb-6">
                    {entry.role}
                </Text>
            )
        }
        {
            entry.description && (
                <Text className="mt-2" size="base">
                    {toPlainText(entry.description)}
                </Text>
            )
        }
        {
            entry.technologies && entry.technologies.length > 0 && (
                <div class="mt-3 flex flex-col gap-x-2 gap-y-1">
                    <Text size="base" className="font-medium mb-2">
                        Technologies I used here:
                    </Text>
                    <ul class="flex flex-wrap items-center gap-4">
                        {entry.technologies.map((item) => (
                            <li class="inline-flex items-center justify-center  ">
                                {item.technology?.svg ? (
                                    <span
                                        aria-hidden="true"
                                        title={getTechnologyLabel(item)}
                                        class="inline-flex h-10 w-10 items-center justify-center [&_svg]:h-10 [&_svg]:w-10 grayscale transition-all duration-300 hover:grayscale-0"
                                        set:html={item.technology.svg}
                                    />
                                ) : (
                                    getTechnologyLabel(item)
                                )}
                            </li>
                        ))}
                    </ul>
                </div>
            )
        }
    </div>
</div>

<script>
    const initExperienceTimelineCardVisibility = () => {
        const cards = document.querySelectorAll(".experience-timeline-card");

        if (cards.length === 0) {
            return;
        }

        const observer = new IntersectionObserver(
            (entries) => {
                entries.forEach((entry) => {
                    const card = entry.target as HTMLElement;

                    if (entry.isIntersecting) {
                        card.classList.add("is-visible");
                        return;
                    }

                    card.classList.remove("is-visible");
                });
            },
            {
                threshold: 0.2,
            },
        );

        cards.forEach((card) => {
            if (card instanceof HTMLElement) {
                observer.observe(card);
            }
        });
    };

    document.addEventListener(
        "astro:page-load",
        initExperienceTimelineCardVisibility,
    );
    initExperienceTimelineCardVisibility();
</script>

<style>
    .experience-timeline-card {
        opacity: 0;
        transition:
            opacity 450ms ease-out,
            box-shadow 300ms ease-out;
    }

    .experience-timeline-card.is-visible {
        opacity: 1;
    }

    @media (prefers-reduced-motion: reduce) {
        .experience-timeline-card {
            transition: none;
        }
    }
</style>
