---
import LogoFooter from "@/assets/Logo_footer.svg";
import PolandFlag from "@/assets/polandflag.svg";
import LinkedinIcon from "@/assets/linkedin.svg";
import InstagramIcon from "@/assets/instagram.svg";
import GithubIcon from "@/assets/github.svg";
import { Mail, Phone, Shield } from "@lucide/astro";
import Text from "@/components/Text/index.astro";
import type { FooterMenuItem, Props } from "./index.type";
import Link from "@/components/Link/index.astro";

const {
    menuItems = [],
    phone = "",
    email = "",
    instagram = "",
    linkedin = "",
    github = "",
} = Astro.props as Props;

type ResolvedFooterMenuItem = FooterMenuItem & {
    title: string;
    slug: string;
};

const resolvedMenuItems: ResolvedFooterMenuItem[] = menuItems.flatMap(
    (item) => {
        if (!item?.title || !item?.slug) {
            return [];
        }

        return [{ ...item, title: item.title, slug: item.slug }];
    },
);

const localePrefix = Astro.url.pathname.startsWith("/pl") ? "/pl" : "";
const homeHref = localePrefix || "/";

const getHref = (slug: string) => {
    if (slug.startsWith("http://") || slug.startsWith("https://")) {
        return slug;
    }

    if (slug.startsWith("/") || slug.startsWith("#")) {
        return slug;
    }

    const localizedSlug =
        localePrefix === "/pl" && slug.endsWith("-pl")
            ? slug.slice(0, -3)
            : slug;

    if (localizedSlug === "home") {
        return homeHref;
    }

    if (!localePrefix) {
        return `/${localizedSlug}`;
    }

    return `${localePrefix}/${localizedSlug}`;
};

const privacyPolicyHref = localePrefix
    ? `${localePrefix}/privacy-policy`
    : "/privacy-policy";

const currentYear = new Date().getFullYear();
---

<footer class="border-t border-paper/20 bg-paper text-ink mt-auto">
    <div
        class="mx-auto grid w-full max-w-600 gap-10 px-6 py-8 md:grid-cols-[1fr_auto_auto]"
    >
        <div class="space-y-4">
            <a href={homeHref} aria-label="Go to homepage" class="inline-flex">
                <LogoFooter />
            </a>
            <div class="flex items-center gap-4 text-sm">
                {
                    linkedin && (
                        <a
                            href={linkedin}
                            target="_blank"
                            rel="noreferrer noopener"
                            class="hover:opacity-70"
                            aria-label="LinkedIn"
                        >
                            <LinkedinIcon class="h-5 w-5" />
                        </a>
                    )
                }
                {
                    instagram && (
                        <a
                            href={instagram}
                            target="_blank"
                            rel="noreferrer noopener"
                            class="hover:opacity-70"
                            aria-label="Instagram"
                        >
                            <InstagramIcon class="h-5 w-5" />
                        </a>
                    )
                }
                {
                    github && (
                        <a
                            href={github}
                            target="_blank"
                            rel="noreferrer noopener"
                            class="hover:opacity-70"
                            aria-label="GitHub"
                        >
                            <GithubIcon class="h-5 w-5" />
                        </a>
                    )
                }
            </div>
        </div>

        {
            resolvedMenuItems.length > 0 && (
                <div class="space-y-3">
                    <Text className="text-sm font-semibold">Quick links</Text>
                    <ul class="space-y-2 text-sm">
                        {resolvedMenuItems.map((item) => (
                            <li>
                                <a
                                    href={getHref(item.slug)}
                                    class="hover:opacity-70"
                                >
                                    {item.title}
                                </a>
                            </li>
                        ))}
                        <li>
                            <a
                                href={`${localePrefix}/contact`}
                                class="hover:opacity-70"
                            >
                                Contact
                            </a>
                        </li>
                    </ul>
                </div>
            )
        }

        <div class="space-y-3">
            <Text className="text-sm font-semibold">Contact</Text>
            <ul class="space-y-2 text-sm">
                {
                    phone && (
                        <li>
                            <a
                                href={`tel:${phone}`}
                                class="inline-flex items-center gap-2 hover:opacity-70"
                            >
                                <Phone class="h-4 w-4" aria-hidden="true" />
                                {phone}
                            </a>
                        </li>
                    )
                }
                {
                    email && (
                        <li>
                            <a
                                href={`mailto:${email}`}
                                class="inline-flex items-center gap-2 hover:opacity-70"
                            >
                                <Mail class="h-4 w-4" aria-hidden="true" />
                                {email}
                            </a>
                        </li>
                    )
                }
            </ul>
        </div>
    </div>
    <div class="border-t border-ink/20">
        <div
            class="mx-auto flex w-full max-w-600 flex-col gap-3 px-6 py-4 text-xs md:flex-row md:items-center md:justify-between"
        >
            <Text>© {currentYear} | Grzegorz Ratajczak</Text>
            <Text className="flex items-center gap-2">
                <PolandFlag class="h-3 w-4 border border-ink/20" />
                Poland
            </Text>
            <Link
                href={privacyPolicyHref}
                className="inline-flex items-center gap-2 hover:opacity-70"
            >
                <Shield class="h-4 w-4" aria-hidden="true" />
                Privacy Policy
            </Link>
        </div>
    </div>
</footer>
