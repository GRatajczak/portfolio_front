---
import type { Props } from "./index.type";
import Heading from "@/components/Heading/index.astro";
import Text from "@/components/Text/index.astro";

const {
    value = "",
    className = "",
    smallHeadings = false,
} = Astro.props as Props;

const escapeHtml = (input: string) =>
    input
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#39;");

const renderSpan = (
    text: string,
    marks: string[] = [],
    markDefs: Record<string, { href?: string }>,
) => {
    return marks.reduce((result, mark) => {
        if (mark === "strong") return `<strong>${result}</strong>`;
        if (mark === "em") return `<em>${result}</em>`;
        if (mark === "code") return `<code>${result}</code>`;
        if (mark === "underline") return `<u>${result}</u>`;
        if (mark === "strike-through") return `<s>${result}</s>`;

        const markDef = markDefs[mark];
        if (markDef?.href) {
            const href = escapeHtml(markDef.href);
            return `<a href="${href}" target="_blank" rel="noreferrer noopener">${result}</a>`;
        }

        return result;
    }, escapeHtml(text));
};

const renderBlockInner = (block: {
    children?: Array<{ text?: string; marks?: string[] }>;
    markDefs?: Array<{ _key: string; href?: string }>;
}) => {
    const markDefs = Object.fromEntries(
        (block.markDefs ?? []).map((item) => [item._key, item]),
    );
    return (block.children ?? [])
        .map((span) => renderSpan(span.text ?? "", span.marks ?? [], markDefs))
        .join("");
};

type PortableTextBlock = {
    _type?: string;
    style?: string;
    listItem?: "bullet" | "number";
    children?: Array<{ text?: string; marks?: string[] }>;
    markDefs?: Array<{ _key: string; href?: string }>;
};

type PortableTextNode =
    | { type: "block"; style?: string; content: string }
    | { type: "list"; listType: "bullet" | "number"; items: string[] };

const headingStyles = new Set(["h1", "h2", "h3", "h4", "h5", "h6"]);

const parsePortableText = (blocks: PortableTextBlock[]) => {
    const nodes: PortableTextNode[] = [];
    let listBuffer: string[] = [];
    let listType: "bullet" | "number" | null = null;

    const flushList = () => {
        if (listBuffer.length === 0 || !listType) {
            listBuffer = [];
            listType = null;
            return;
        }

        nodes.push({
            type: "list",
            listType,
            items: [...listBuffer],
        });
        listBuffer = [];
        listType = null;
    };

    for (const block of blocks) {
        if (block._type !== "block") {
            continue;
        }

        const inner = renderBlockInner(block);

        if (block.listItem) {
            if (listType && listType !== block.listItem) {
                flushList();
            }
            listType = block.listItem;
            listBuffer.push(inner);
            continue;
        }

        flushList();
        if (inner.trim()) {
            nodes.push({
                type: "block",
                style: block.style,
                content: inner,
            });
        }
    }

    flushList();
    return nodes;
};

const parsedNodes = Array.isArray(value) ? parsePortableText(value) : [];
---

{
    Array.isArray(value) ? (
        <div class={className}>
            {parsedNodes.map((node) => {
                if (node.type === "list") {
                    return node.listType === "number" ? (
                        <ol class="list-decimal list-outside pl-5 space-y-1">
                            {node.items.map((item) => (
                                <li>
                                    <Text as="span">
                                        <Fragment set:html={item} />
                                    </Text>
                                </li>
                            ))}
                        </ol>
                    ) : (
                        <ul class="list-disc list-outside pl-5 space-y-1">
                            {node.items.map((item) => (
                                <li>
                                    <Text as="span">
                                        <Fragment set:html={item} />
                                    </Text>
                                </li>
                            ))}
                        </ul>
                    );
                }

                if (headingStyles.has(node.style ?? "")) {
                    const headingTag = node.style as
                        | "h1"
                        | "h2"
                        | "h3"
                        | "h4"
                        | "h5"
                        | "h6";
                    return (
                        <Heading
                            as={headingTag}
                            size={smallHeadings ? "xl" : undefined}
                            className={smallHeadings ? "font-semibold" : ""}
                        >
                            <Fragment set:html={node.content} />
                        </Heading>
                    );
                }

                if (node.style === "blockquote") {
                    return (
                        <blockquote>
                            <Text>
                                <Fragment set:html={node.content} />
                            </Text>
                        </blockquote>
                    );
                }

                return (
                    <Text>
                        <Fragment set:html={node.content} />
                    </Text>
                );
            })}
        </div>
    ) : (
        <div class={className}>
            <slot>{value}</slot>
        </div>
    )
}
