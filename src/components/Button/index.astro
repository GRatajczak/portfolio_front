---
import type { Props } from "./index.type";
import { ArrowUpRight } from "@lucide/astro";

const {
    href = "",
    label = "",
    type = "button",
    isExternal = false,
    className = "",
    showArrowUp = false,
    mobileIconOnly = false,
} = Astro.props as Props;
---

{
    href ? (
        <a
            class={`inline-flex items-center rounded-full border border-zinc-300 px-4 py-2 text-sm font-medium text-paper hover:border-zinc-500 ${className}`}
            href={href}
            target={isExternal ? "_blank" : undefined}
            rel={isExternal ? "noreferrer noopener" : undefined}
        >
            <span class={mobileIconOnly ? "sr-only md:not-sr-only" : ""}>
                <slot>{label}</slot>
            </span>
            {showArrowUp && (
                <ArrowUpRight
                    aria-hidden="true"
                    class={mobileIconOnly ? "size-6 md:ml-2" : "ml-2 size-6"}
                />
            )}
        </a>
    ) : (
        <button
            class={`inline-flex items-center rounded-full border border-zinc-300 px-4 py-2 text-sm font-medium text-paper hover:border-zinc-500 ${className}`}
            type={type}
        >
            <span class={mobileIconOnly ? "sr-only md:not-sr-only" : ""}>
                <slot>{label}</slot>
            </span>
            {showArrowUp && (
                <ArrowUpRight
                    aria-hidden="true"
                    class={mobileIconOnly ? "size-6 md:ml-2" : "ml-2 size-6"}
                />
            )}
        </button>
    )
}
