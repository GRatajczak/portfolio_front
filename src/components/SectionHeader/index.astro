---
import type { Props } from "./index.type";
import Heading from "../Heading/index.astro";

const {
    eyebrow = "",
    heading = "",
    description = "",
    className = "",
    headingAs = "h2",
} = Astro.props as Props;
---

<div class={`space-y-2 ${className}`}>
    {
        eyebrow && (
            <p
                class="font-semibold uppercase text-paper"
                style="font-size: var(--font-size-sm);"
            >
                {eyebrow}
            </p>
        )
    }
    {
        heading && (
            <Heading
                as={headingAs}
                text={heading}
                className="leading-tight text-paper"
                style="font-size: var(--font-size-4xl);"
            />
        )
    }
    {
        description && (
            <p
                class="leading-7 text-paper"
                style="font-size: var(--font-size-lg);"
            >
                {description}
            </p>
        )
    }
</div>
