---
import type { Props } from "./index.type";
import Heading from "../Heading/index.astro";
import Text from "../Text/index.astro";

const {
    eyebrow = "",
    heading = "",
    description = "",
    className = "",
    hero = false,
    headingAs = "h2",
} = Astro.props as Props;
---

<div class={`space-y-2 max-w-300 ${className}`}>
    {
        eyebrow && (
            <Text size="xs" className="font-semibold uppercase">
                {eyebrow}
            </Text>
        )
    }
    {
        heading && (
            <Heading
                as={headingAs}
                text={heading}
                size={hero ? "display" : "5xl"}
            />
        )
    }
    {
        description && (
            <Text size="lg" className="max-w-[90%] pb-4">
                {description}
            </Text>
        )
    }
    <div class="section-header-line h-px w-full bg-paper/30"></div>
</div>

<style>
    .section-header-line {
        transform-origin: left;
        animation: sectionHeaderLineIn 700ms ease-out forwards;
        transform: scaleX(0);
    }

    @keyframes sectionHeaderLineIn {
        from {
            transform: scaleX(0);
        }
        to {
            transform: scaleX(1);
        }
    }
</style>
