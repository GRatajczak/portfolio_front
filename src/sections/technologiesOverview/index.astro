---
import Container from "@/components/Container/index.astro";
import SectionHeader from "@/components/SectionHeader/index.astro";
import Text from "@/components/Text/index.astro";
import { getTechnologyLabel, toPlainText } from "@/utils/pageBuilder/helpers";
import type { Props } from "./index.type";

const { heading = "", description = [], groups = [] } = Astro.props as Props;
const descriptionText = toPlainText(description);
const groupsWithTechnologies = groups.filter(
    (group) => (group.technologies?.length ?? 0) > 0,
);
---

<Container>
    <div class="grid gap-10 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] lg:items-start">
        <SectionHeader
            heading={heading}
            description={descriptionText}
            className="max-w-xl"
        />

        {
            groupsWithTechnologies.length > 0 ? (
                <div data-tech-tabs>
                    <div
                        role="tablist"
                        aria-label="Technology groups"
                        class="flex flex-wrap items-center gap-2 border-b border-paper/40 pb-2"
                    >
                        {groupsWithTechnologies.map((group, index) => {
                            const tabId = `technologies-overview-tab-${index}`;
                            const panelId = `technologies-overview-panel-${index}`;
                            return (
                                <button
                                    id={tabId}
                                    type="button"
                                    role="tab"
                                    aria-selected={index === 0 ? "true" : "false"}
                                    aria-controls={panelId}
                                    data-tab-index={index}
                                    tabindex={index === 0 ? 0 : -1}
                                    class:list={[
                                        "cursor-pointer border-none bg-transparent px-1 py-1 text-left text-sm font-semibold transition-colors md:text-base",
                                        index === 0
                                            ? "text-paper"
                                            : "text-paper/55 hover:text-paper/80",
                                    ]}
                                >
                                    {group.label || `Group ${index + 1}`}
                                </button>
                            );
                        })}
                    </div>

                    <div class="pt-6">
                        {groupsWithTechnologies.map((group, index) => {
                            const tabId = `technologies-overview-tab-${index}`;
                            const panelId = `technologies-overview-panel-${index}`;
                            return (
                                <section
                                    id={panelId}
                                    role="tabpanel"
                                    aria-labelledby={tabId}
                                    hidden={index !== 0}
                                    data-panel-index={index}
                                >
                                    <ul class="flex flex-wrap items-center gap-5">
                                        {(group.technologies ?? []).map((technology) => {
                                            const technologySvg = (
                                                technology.technology as
                                                    | { svg?: string }
                                                    | undefined
                                            )?.svg;
                                            return (
                                                <li class="inline-flex min-h-10 min-w-10 items-center justify-center">
                                                    {technologySvg ? (
                                                    <span
                                                        aria-hidden="true"
                                                        title={getTechnologyLabel(technology)}
                                                        class="inline-flex h-12 w-12 items-center justify-center [&_svg]:h-12 [&_svg]:w-12 grayscale transition-all duration-300 hover:grayscale-0"
                                                        set:html={technologySvg}
                                                    />
                                                ) : (
                                                    <span class="rounded-full border border-paper/35 px-3 py-1 text-xs text-paper sm:text-sm">
                                                        {getTechnologyLabel(technology)}
                                                    </span>
                                                )}
                                                </li>
                                            );
                                        })}
                                    </ul>
                                </section>
                            );
                        })}
                    </div>
                </div>
            ) : (
                <Text>No technology groups configured.</Text>
            )
        }
    </div>
 </Container>

<script>
    const initTechnologiesTabs = () => {
        const tabsContainer = document.querySelector("[data-tech-tabs]");
        if (!(tabsContainer instanceof HTMLElement)) {
            return;
        }

        const tabs = Array.from(
            tabsContainer.querySelectorAll<HTMLButtonElement>("[role='tab']"),
        );
        const panels = Array.from(
            tabsContainer.querySelectorAll<HTMLElement>("[role='tabpanel']"),
        );
        if (tabs.length === 0 || panels.length === 0) {
            return;
        }

        const activateTab = (targetIndex: number, shouldFocus = false) => {
            tabs.forEach((tab, index) => {
                const isActive = index === targetIndex;
                tab.setAttribute("aria-selected", isActive ? "true" : "false");
                tab.tabIndex = isActive ? 0 : -1;
                tab.classList.toggle("text-paper", isActive);
                tab.classList.toggle("text-paper/55", !isActive);
                tab.classList.toggle("hover:text-paper/80", !isActive);

                if (isActive && shouldFocus) {
                    tab.focus();
                }
            });

            panels.forEach((panel, index) => {
                panel.hidden = index !== targetIndex;
            });
        };

        tabs.forEach((tab, index) => {
            tab.addEventListener("click", () => activateTab(index, true));
            tab.addEventListener("keydown", (event) => {
                if (!(event instanceof KeyboardEvent)) {
                    return;
                }

                const lastIndex = tabs.length - 1;
                let nextIndex = index;

                if (event.key === "ArrowRight") {
                    nextIndex = index === lastIndex ? 0 : index + 1;
                } else if (event.key === "ArrowLeft") {
                    nextIndex = index === 0 ? lastIndex : index - 1;
                } else if (event.key === "Home") {
                    nextIndex = 0;
                } else if (event.key === "End") {
                    nextIndex = lastIndex;
                } else {
                    return;
                }

                event.preventDefault();
                activateTab(nextIndex, true);
            });
        });
    };

    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initTechnologiesTabs, {
            once: true,
        });
    } else {
        initTechnologiesTabs();
    }
</script>
