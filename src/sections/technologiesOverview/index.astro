---
import Container from "@/components/Container/index.astro";
import SectionHeader from "@/components/SectionHeader/index.astro";
import { getTechnologyLabel, toPlainText } from "@/utils/pageBuilder/helpers";
import type { Props } from "./index.type";

const { heading = "", description = [], groups = [] } = Astro.props as Props;
const descriptionText = toPlainText(description);
---

<Container>
    <SectionHeader heading={heading} description={descriptionText} />

    {
        groups.length > 0 ? (
            <div class="space-y-4">
                {groups.map((group) => (
                    <article class="rounded-2xl border  p-4">
                        {group.label && <h3 class="text-lg font-medium text-paper">{group.label}</h3>}
                        <ul class="mt-2 flex flex-wrap gap-2">
                            {(group.technologies ?? []).map((technology) => (
                                <li class="rounded-full bg-zinc-100 px-3 py-1 text-sm text-paper">
                                    {getTechnologyLabel(technology)}
                                </li>
                            ))}
                        </ul>
                    </article>
                ))}
            </div>
        ) : (
            <p class="text-paper">No technology groups configured.</p>
        )
    }
</Container>
