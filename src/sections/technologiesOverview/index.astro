---
import Container from "@/components/Container/index.astro";
import Heading from "@/components/Heading/index.astro";
import SectionHeader from "@/components/SectionHeader/index.astro";
import Text from "@/components/Text/index.astro";
import { getTechnologyLabel, toPlainText } from "@/utils/pageBuilder/helpers";
import type { Props } from "./index.type";

const { heading = "", description = [], groups = [] } = Astro.props as Props;
const descriptionText = toPlainText(description);
---

<Container>
    <SectionHeader heading={heading} description={descriptionText} />

    {
        groups.length > 0 ? (
            <div class="technologies-overview-slider">
                {groups.map((group) => (
                    <article class="rounded-2xl border p-4">
                        {group.label && (
                            <Heading
                                as="h3"
                                className="text-lg font-medium text-paper"
                            >
                                {group.label}
                            </Heading>
                        )}
                        <div class="mt-2">
                            <swiper-container
                                class="technologies-swiper"
                                init="false"
                            >
                                {(group.technologies ?? []).map(
                                    (technology) => (
                                        <swiper-slide>
                                            <span class="rounded-full bg-zinc-100 px-3 py-1 text-sm text-paper">
                                                {getTechnologyLabel(technology)}
                                            </span>
                                        </swiper-slide>
                                    ),
                                )}
                            </swiper-container>
                        </div>
                    </article>
                ))}
            </div>
        ) : (
            <Text className="text-paper">No technology groups configured.</Text>
        )
    }
</Container>

<script>
    import { register } from "swiper/element/bundle";

    register();

    const initTechnologiesSwipers = () => {
        document.querySelectorAll(".technologies-swiper").forEach((swiperCandidate) => {
                if (
                    !(swiperCandidate instanceof HTMLElement) ||
                    swiperCandidate.dataset.initialized === "true"
                ) {
                    return;
                }

                const slidesCount = swiperCandidate.querySelectorAll("swiper-slide").length;
                if (slidesCount < 2) {
                    return;
                }

                const swiperEl = swiperCandidate as HTMLElement & {
                    initialize: () => void;
                };

                if (typeof swiperEl.initialize !== "function") {
                    return;
                }

                Object.assign(swiperEl, {
                    slidesPerView: "auto",
                    spaceBetween: 12,
                    loop: true,
                    speed: 3800,
                    allowTouchMove: false,
                    freeMode: true,
                    freeModeMomentum: false,
                    autoplay: {
                        delay: 1,
                        disableOnInteraction: false,
                        pauseOnMouseEnter: false,
                    },
                    injectStyles: [
                        `
                            .swiper-wrapper {
                                transition-timing-function: linear !important;
                            }
                            .swiper-slide {
                                width: auto !important;
                            }
                        `,
                    ],
                });

                swiperEl.initialize();
                swiperEl.dataset.initialized = "true";
            });
    };

    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initTechnologiesSwipers, {
            once: true,
        });
    } else {
        initTechnologiesSwipers();
    }
</script>
