---
import Container from "@/components/Container/index.astro";
import { toPlainText } from "@/utils/pageBuilder/helpers";
import type { Props } from "./index.type";

const { heading = "", description = [], project } = Astro.props as Props;
const descriptionText = toPlainText(description);
---

<Container>
    {heading && <h2 class="text-3xl font-semibold text-paper">{heading}</h2>}
    {descriptionText && <p class="text-base leading-7 text-paper">{descriptionText}</p>}

    {project?.title && (
        <article class="rounded-2xl border border-zinc-100 p-4">
            {project.category && <p class="text-sm uppercase tracking-[0.12em] text-paper">{project.category}</p>}
            <h3 class="text-xl font-medium text-paper">{project.title}</h3>
            {project.description && <p class="mt-2 text-paper">{project.description}</p>}
            {project.technologies && project.technologies.length > 0 && (
                <p class="mt-2 text-sm text-paper">Tech: {project.technologies.join(", ")}</p>
            )}
            {project.button?.buttonText && project.button.buttonLink && (
                <a
                    class="mt-3 inline-flex items-center rounded-full border border-zinc-300 px-4 py-2 text-sm font-medium text-paper hover:border-zinc-500"
                    href={project.button.buttonLink}
                    target={project.button.isExternalLink ? "_blank" : undefined}
                    rel={project.button.isExternalLink ? "noreferrer noopener" : undefined}
                >
                    {project.button.buttonText}
                </a>
            )}
        </article>
    )}
</Container>
