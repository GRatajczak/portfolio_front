---
import Container from "@/components/Container/index.astro";
import { getProjectLabel } from "@/utils/pageBuilder/helpers";
import type { Props } from "./index.type";

const { eyebrow = "", heading = "", projects = [], button } = Astro.props as Props;
---

<Container>
    {eyebrow && <p class="text-sm font-semibold uppercase tracking-[0.16em] text-paper">{eyebrow}</p>}
    {heading && <h2 class="text-3xl font-semibold text-paper">{heading}</h2>}

    {
        projects.length > 0 ? (
            <ul class="space-y-2">
                {projects.map((project) => (
                    <li class="rounded-2xl border border-zinc-100 px-4 py-3 text-paper">{getProjectLabel(project)}</li>
                ))}
            </ul>
        ) : (
            <p class="text-paper">No projects configured.</p>
        )
    }

    {button?.buttonText && button.buttonLink && (
        <a
            class="inline-flex items-center rounded-full border border-zinc-300 px-4 py-2 text-sm font-medium text-paper hover:border-zinc-500"
            href={button.buttonLink}
            target={button.isExternalLink ? "_blank" : undefined}
            rel={button.isExternalLink ? "noreferrer noopener" : undefined}
        >
            {button.buttonText}
        </a>
    )}
</Container>
