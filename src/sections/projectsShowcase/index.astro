---
import Container from "@/components/Container/index.astro";
import Link from "@/components/Link/index.astro";
import SectionHeader from "@/components/SectionHeader/index.astro";
import { getProjectLabel } from "@/utils/pageBuilder/helpers";
import type { Props } from "./index.type";

const {
    eyebrow = "",
    heading = "",
    projects = [],
    button,
} = Astro.props as Props;
---

<Container>
    <SectionHeader eyebrow={eyebrow} heading={heading} />

    {
        projects.length > 0 ? (
            <ul class="space-y-2">
                {projects.map((project) => (
                    <li class="rounded-2xl border border-zinc-100 px-4 py-3 text-paper">
                        {getProjectLabel(project)}
                    </li>
                ))}
            </ul>
        ) : (
            <p class="text-paper">No projects configured.</p>
        )
    }

    <Link
        href={button?.buttonLink}
        label={button?.buttonText}
        isExternal={button?.isExternalLink}
    />
</Container>
