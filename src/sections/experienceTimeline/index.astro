---
import Container from "@/components/Container/index.astro";
import Heading from "@/components/Heading/index.astro";
import SectionHeader from "@/components/SectionHeader/index.astro";
import Text from "@/components/Text/index.astro";
import { toPlainText } from "@/utils/pageBuilder/helpers";
import type { Props } from "./index.type";

const { eyebrow = "", heading = "", entries = [] } = Astro.props as Props;
---

<Container>
    <SectionHeader eyebrow={eyebrow} heading={heading} />

    {
        entries.length > 0 ? (
            <ol class="space-y-4">
                {entries.map((entry) => (
                    <li class="rounded-2xl border border-zinc-100 p-4">
                        <Text className="text-sm text-paper">{entry.period}</Text>
                        <Heading as="h3" className="text-lg font-medium text-paper">
                            {entry.company}
                        </Heading>
                        {entry.role && <Text className="text-sm text-paper">{entry.role}</Text>}
                        {entry.description && (
                            <Text className="mt-2 text-paper">
                                {toPlainText(entry.description)}
                            </Text>
                        )}
                        {entry.technologies && entry.technologies.length > 0 && (
                            <Text className="mt-2 text-sm text-paper">
                                Stack: {entry.technologies.join(", ")}
                            </Text>
                        )}
                    </li>
                ))}
            </ol>
        ) : (
            <Text className="text-paper">No experience entries configured.</Text>
        )
    }
</Container>
