---
import Container from "@/components/Container/index.astro";
import SectionHeader from "@/components/SectionHeader/index.astro";
import Text from "@/components/Text/index.astro";
import { ArrowUpRight } from "@lucide/astro";
import { Image } from "astro:assets";
import type { Props } from "./index.type";
import Button from "@/components/Button/index.astro";

const {
    eyebrow = "",
    heading = "",
    certificates = [],
    button = {},
} = Astro.props as Props;
---

<div>
    <Container className="mb-0! flex items-center justify-between">
        <SectionHeader eyebrow={eyebrow} heading={heading} />
        {
            button && (
                <Button
                    href={button.buttonLink}
                    isExternal={button.isExternalLink}
                    label={button.buttonText}
                    showArrowUp
                />
            )
        }
    </Container>

    {
        certificates.length > 0 ? (
            <div class="certificates-gallery px-0 py-4 md:p-6">
                <swiper-container class="certificates-swiper" init="false">
                    {certificates.map((item) => {
                        const certificate = item.certificate ?? item;
                        const imageUrl = certificate.image?.asset?.url;
                        const imageWidth =
                            certificate.image?.asset?.metadata?.dimensions
                                ?.width;
                        const imageHeight =
                            certificate.image?.asset?.metadata?.dimensions
                                ?.height;
                        const certificateUrl = certificate.certificateUrl;
                        const certificateHref = certificateUrl || imageUrl;
                        const imageAlt =
                            certificate.image?.alt ||
                            certificate.title ||
                            "Certificate preview";

                        return (
                            <swiper-slide>
                                <article class="group overflow-hidden rounded-xl border border-paper/20">
                                    {imageUrl &&
                                    imageWidth &&
                                    imageHeight &&
                                    certificateHref ? (
                                        <a
                                            href={certificateHref}
                                            target="_blank"
                                            rel="noreferrer noopener"
                                            aria-label={`Open ${imageAlt}`}
                                            class="relative block"
                                        >
                                            <Image
                                                src={imageUrl}
                                                alt={imageAlt}
                                                width={imageWidth}
                                                height={imageHeight}
                                                class="h-56 w-full object-contain md:h-96"
                                                loading="lazy"
                                                format="webp"
                                            />
                                            <span
                                                class="absolute top-3 right-3 inline-flex h-10 w-10 items-center justify-center rounded-full border border-paper/60 bg-ink/80 text-paper opacity-100 transition-opacity duration-200 md:opacity-0 md:group-hover:opacity-100 md:group-focus-within:opacity-100"
                                                aria-hidden="true"
                                            >
                                                <ArrowUpRight class="size-5" />
                                            </span>
                                        </a>
                                    ) : imageUrl &&
                                      imageWidth &&
                                      imageHeight ? (
                                        <Image
                                            src={imageUrl}
                                            alt={imageAlt}
                                            width={imageWidth}
                                            height={imageHeight}
                                            class="h-56 w-full object-contain md:h-96"
                                            loading="lazy"
                                            format="webp"
                                        />
                                    ) : (
                                        <div class="flex h-56 items-center justify-center text-paper/60 md:h-72">
                                            No certificate image
                                        </div>
                                    )}
                                </article>
                            </swiper-slide>
                        );
                    })}
                </swiper-container>

                <div class="mt-4 flex items-center justify-center gap-3">
                    <button
                        type="button"
                        class="certificates-swiper-prev inline-flex h-9 w-9 items-center justify-center rounded-full border border-paper/40 text-paper transition-colors hover:border-paper"
                        aria-label="Previous certificate"
                    >
                        <span aria-hidden="true">&larr;</span>
                    </button>
                    <button
                        type="button"
                        class="certificates-swiper-next inline-flex h-9 w-9 items-center justify-center rounded-full border border-paper/40 text-paper transition-colors hover:border-paper"
                        aria-label="Next certificate"
                    >
                        <span aria-hidden="true">&rarr;</span>
                    </button>
                </div>
            </div>
        ) : (
            <Text className="text-paper">No certificates configured.</Text>
        )
    }
</div>

<script>
    import { register } from "swiper/element/bundle";

    register();

    const initCertificatesSwipers = () => {
        document
            .querySelectorAll(".certificates-gallery")
            .forEach((gallery) => {
                const swiperEl = gallery.querySelector("swiper-container");
                const nextEl = gallery.querySelector(
                    ".certificates-swiper-next",
                );
                const prevEl = gallery.querySelector(
                    ".certificates-swiper-prev",
                );

                if (
                    !swiperEl ||
                    !nextEl ||
                    !prevEl ||
                    swiperEl.dataset.initialized === "true"
                ) {
                    return;
                }

                Object.assign(swiperEl, {
                    slidesPerView: 1.15,
                    spaceBetween: 16,
                    breakpoints: {
                        768: {
                            slidesPerView: 2.1,
                            spaceBetween: 20,
                        },
                        1024: {
                            slidesPerView: 2.5,
                            spaceBetween: 24,
                        },
                    },
                    navigation: {
                        nextEl,
                        prevEl,
                    },
                    keyboard: {
                        enabled: true,
                    },
                });

                swiperEl.initialize();
                swiperEl.dataset.initialized = "true";
            });
    };

    document.addEventListener("astro:page-load", initCertificatesSwipers);
    initCertificatesSwipers();
</script>
