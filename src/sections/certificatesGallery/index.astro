---
import Container from "@/components/Container/index.astro";
import SectionHeader from "@/components/SectionHeader/index.astro";
import Text from "@/components/Text/index.astro";
import type { Props } from "./index.type";

const { eyebrow = "", heading = "", certificates = [] } = Astro.props as Props;
---

<Container>
    <SectionHeader eyebrow={eyebrow} heading={heading} />

    {
        certificates.length > 0 ? (
            <ul class="space-y-2">
                {certificates.map((certificate) => (
                    <li class="rounded-2xl border border-zinc-100 px-4 py-3">
                        <Text className="font-medium text-paper">
                            {certificate.title || "Untitled certificate"}
                        </Text>
                        {certificate.issuer && (
                            <Text className="text-sm text-paper">{certificate.issuer}</Text>
                        )}
                    </li>
                ))}
            </ul>
        ) : (
            <Text className="text-paper">No certificates configured.</Text>
        )
    }
</Container>
