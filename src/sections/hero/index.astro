---
import { Image } from "astro:assets";
import Container from "@/components/Container/index.astro";
import type { Props } from "./index.type";

const { headline = "", subheadline = [], portraitImage } = Astro.props as Props;
const subheadlineText = subheadline
    .map((item) => item.text)
    .filter(Boolean)
    .join(" ");
const portraitImageUrl = portraitImage?.asset?.url;
const portraitImageWidth = portraitImage?.asset?.metadata?.dimensions?.width;
const portraitImageHeight = portraitImage?.asset?.metadata?.dimensions?.height;
const portraitImageAlt = portraitImage?.alt || "Portrait photo";
---

<Container>
    {
        portraitImageUrl && portraitImageWidth && portraitImageHeight && (
            <Image
                src={portraitImageUrl}
                alt={portraitImageAlt}
                width={portraitImageWidth}
                height={portraitImageHeight}
                class="mb-6 h-auto w-40 rounded-2xl object-cover sm:w-52"
                loading="eager"
                format="webp"
            />
        )
    }
    {headline && <h1 class="text-4xl font-semibold text-paper">{headline}</h1>}
    {
        subheadlineText && (
            <p class="text-lg leading-8 text-paper">{subheadlineText}</p>
        )
    }
</Container>
