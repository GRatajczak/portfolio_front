---
import { Image } from "astro:assets";
import Heading from "@/components/Heading/index.astro";
import Text from "@/components/Text/index.astro";
import type { Props } from "./index.type";

const { headline = "", subheadline = [], portraitImage } = Astro.props as Props;
const subheadlineText = subheadline
    .map((item) => item.text)
    .filter(Boolean)
    .join(" ");
const portraitImageUrl = portraitImage?.asset?.url;
const portraitImageWidth =
    portraitImage?.asset?.metadata?.dimensions?.width ?? 900;
const portraitImageHeight =
    portraitImage?.asset?.metadata?.dimensions?.height ?? 1200;
const portraitImageAlt = portraitImage?.alt || "Portrait photo";
---

<section
    class="flex items-end justify-between h-full max-h-screen mx-auto px-6 relative"
>
    <div class="w-[60%] pb-8 min-h-screen flex flex-col justify-end">
        {
            subheadlineText && (
                <Text size="lg" className="opacity-70">
                    {subheadline[0].text}
                </Text>
            )
        }
        {
            headline && (
                <Heading
                    as="h1"
                    text={headline}
                    size="display"
                    className="font-semibold mb-5 tracking-wide"
                />
            )
        }
    </div>
    {
        portraitImageUrl && (
            <Image
                src={portraitImageUrl}
                alt={portraitImageAlt}
                width={portraitImageWidth}
                height={portraitImageHeight}
                class="hero-portrait-shadow mt-6 h-auto max-h-[60vh] w-full object-cover hidden! border-paper/30 lg:mt-0 lg:block! lg:max-h-screen lg:h-full lg:w-[40%] lg:border-l absolute lg:right-0 lg:bottom-0 lg:top-0"
                loading="eager"
                format="webp"
            />
        )
    }
</section>

<style>
    .hero-portrait-shadow {
        animation: heroShadowIn 1s 1s ease-out forwards;
    }

    @keyframes heroShadowIn {
        0% {
            box-shadow: 0 0 0 rgba(236, 236, 231, 0);
        }
        100% {
            box-shadow: 0 0 64px rgba(236, 236, 231, 0.05);
        }
    }
</style>
